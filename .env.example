# Supabase - lấy từ Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Supabase PostgreSQL - lấy từ Project Settings > Database > Connection string (URI mode)
# Thêm ?pgbouncer=true&connection_limit=1 vào cuối DATABASE_URL
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.supabase.com:5432/postgres

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here-change-this
NEXTAUTH_URL=http://localhost:3000

# Tài khoản Ba và Mẹ (bcrypt hash của mật khẩu)
# Tạo hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('matkhau',10))"
BA_EMAIL=ba@khoi.family
BA_PASSWORD_HASH=$2a$10$...
ME_EMAIL=me@khoi.family
ME_PASSWORD_HASH=$2a$10$...
